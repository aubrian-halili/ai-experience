{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "aws-sam",
            "request": "direct-invoke",
            "name": "Invoke Lambda (TypeScript)",
            "preLaunchTask": "build",
            "aws": {
                "credentials": "profile:test",
                "region": "eu-west-1"
            },
            "invokeTarget": {
                "target": "code",
                "projectRoot": "${workspaceFolder}/dist",
                "lambdaHandler": "lambdas/api/application/accept-offer/index.handler"
            },
            "lambda": {
                "runtime": "nodejs22.x",
                "memoryMb": 2048,
                "payload": {
                    "path": ".localenv/payload/accept-offer.json"
                },
                "environmentVariables": {
                    "ENVIRONMENT": "test",
                    "AWS_REGION": "eu-west-1"
                }
            }
        }
    ]
}