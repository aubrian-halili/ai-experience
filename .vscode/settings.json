{
  "workbench.colorTheme": "GitHub Light Default",
  "extensions.autoUpdate": true,
  "extensions.autoCheckUpdates": true,
  "extensions.ignoreRecommendations": true,
  "aws.cloudformation.telemetry.enabled": true,
  "editor.tabSize": 2,
  "editor.renderWhitespace": "all",
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.stickyScroll.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.insertMode": "replace",
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "git.allowForcePush": true,
  "git.autofetch": true,
  "git.fetchOnPull": true,
  "git.confirmSync": false,
  "git.rebaseWhenSync": true,
  "git.detectSubmodules": false,
  "git.detectSubmodulesLimit": 0,
  "git.pruneOnFetch": true,
  "git.branchProtection": [
    "main",
    "master"
  ],
  "git.openRepositoryInParentFolders": "always",
  "git.mergeEditor": true,
  "git.inputValidation": true,
  "git.inputValidationSubjectLength": 72,
  "scm.defaultViewMode": "tree",
  "scm.diffDecorations": "gutter",
  "scm.graph.badges": "all",
  "diffEditor.ignoreTrimWhitespace": false,
  "search.exclude": {
    "**/node_modules": true,
    ".git": true,
    "**/dist": true,
    "**/build": true
  },
  "terminal.integrated.scrollback": 50000,
  "terminal.integrated.stickyScroll.enabled": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.shellIntegration.decorationsEnabled": "both",
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.integrated.tabs.hideCondition": "never",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.enableVisualBell": true,
  "terminal.integrated.wordSeparators": " ()[]{}',\"`\u2500\u2018\u2019|",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.rightClickBehavior": "selectWord",
  "terminal.integrated.profiles.osx": {
    "claude": {
      "path": "zsh",
      "args": [
        "-l"
      ],
      "icon": "terminal",
      "env": {
        "CLAUDE_CODE": "1"
      }
    }
  },
  "claudeCode.preferredLocation": "panel",
  "claudeCode.autosave": true,
  "claudeCode.respectGitIgnore": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "inlineChat.defaultModel": "GPT-4.1 (copilot)",
  "chat.planAgent.defaultModel": "GPT-4.1 (copilot)",
  "gitlens.advanced.repositorySearchDepth": 0,
  "gitlens.currentLine.enabled": true,
  "gitlens.currentLine.format": "${author}, ${agoOrDate} \u00b7 ${message}",
  "gitlens.statusBar.enabled": true,
  "gitlens.statusBar.command": "gitlens.showQuickCommitDetails",
  "gitlens.statusBar.format": "${author}, ${agoOrDate}",
  "gitlens.blame.format": "${author|20} ${agoOrDate|14} ${message|50}",
  "gitlens.blame.highlight.locations": [
    "gutter",
    "line",
    "overview"
  ],
  "gitlens.hovers.enabled": true,
  "gitlens.hovers.currentLine.over": "annotation",
  "gitlens.hovers.detailsMarkdownFormat": "${author} ${agoAndDateBothSources}${message}${\n\n---\n\nfootnotes}\n\n${commands}",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": false,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": false,
    "repositories": true,
    "searchAndCompare": false,
    "launchpad": true
  },
  "extensions.allowed": {
    "amazonwebservices.aws-toolkit-vscode": true,
    "github.github-vscode-theme": true,
    "eamodio.gitlens": true,
    "anthropic.claude-code": true
  }
}